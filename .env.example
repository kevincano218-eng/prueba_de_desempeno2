# VoiceAgent — Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# ----- LLM (required) -----
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ----- Tool: Web Search (required for Tool 1) -----
# Get your free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ----- Tool: Weather (required for Tool 2) -----
# Get your free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ----- TTS: ElevenLabs (primary, optional) -----
# Get your key at https://elevenlabs.io
# Leave blank to fall back to OpenAI TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ----- TTS: OpenAI (fallback, optional) -----
# Required if ELEVENLABS_API_KEY is not set
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_VOICE=nova

# ----- RAG (optional — bonus points) -----
# URL to scrape for the knowledge base
# Example: https://en.wikipedia.org/wiki/Artificial_intelligence
RAG_SOURCE_URL=
